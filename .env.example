# ===========================================
# 联系表单 — 复制本文件为 .env.local 并填写
# ===========================================

# ── 选择邮件服务（三选一）────────────────────
# resend   → 服务端发送，API Key 不暴露（推荐）
# emailjs  → 纯前端发送，配置简单
# mailto   → 打开本地邮件客户端，无需配置
NEXT_PUBLIC_CONTACT_PROVIDER=resend

# ── Resend 配置 ─────────────────────────────
# 1. 注册 https://resend.com → API Keys 创建密钥
# 2. 测试可用 onboarding@resend.dev 作为发件人
# 3. 正式上线需在 Resend 验证你的域名
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=your@email.com
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# ── EmailJS 配置（若 PROVIDER=emailjs）──────
# 1. 注册 https://www.emailjs.com/
# 2. 创建 Email Service + Email Template
# 3. 模板变量建议使用: {{from_name}} {{reply_to}} {{message}} {{to_name}}
# NEXT_PUBLIC_CONTACT_PROVIDER=emailjs
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# 可选：邮件主题中的站点名
# NEXT_PUBLIC_SITE_NAME=陈鹏 Portfolio

# 站点 URL（SEO、sitemap、OG 图）
NEXT_PUBLIC_SITE_URL=https://chenpeng.dev

# ── 访问统计 Dashboard ───────────────────────
# 设置后访问 /admin/analytics 输入相同密钥
ADMIN_SECRET=your-admin-secret-here
